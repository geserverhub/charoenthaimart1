generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model CtmProduct {
  id          String   @id @default(cuid())
  productCode String?  @unique
  barcode     String?  @unique
  name        String
  nameKo      String?
  category    String?
  buyPrice    Decimal  @db.Decimal(10, 2)
  sellPrice   Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  unit        String?  @default("ชิ้น")
  imageUrl    String?
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saleItems  CtmSaleItem[]
  promotions CtmPromotion[]
  stockLogs  CtmStockLog[]

  @@index([barcode])
  @@index([category])
}


model CtmStockLog {
  id        String   @id @default(cuid())
  productId String
  delta     Int
  note      String?  @db.Text
  createdAt DateTime @default(now())

  product CtmProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}


model CtmPromotion {
  id         String   @id @default(cuid())
  promoCode  String?  @unique
  productId  String
  promoPrice Decimal  @db.Decimal(10, 2)
  label      String?
  note       String?
  isActive   Boolean  @default(true)
  startDate  DateTime @default(now())
  endDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product CtmProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isActive])
}


model CtmSale {
  id          String   @id @default(cuid())
  number      String   @unique
  customerId  String?
  totalAmount Decimal  @db.Decimal(10, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(10, 2)
  paymentType String   @default("CASH")
  note        String?  @db.Text
  saleDate    DateTime @default(now())
  createdAt   DateTime @default(now())

  customer CtmCustomer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    CtmSaleItem[]

  @@index([customerId])
  @@index([saleDate])
}


model CtmSaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  buyPrice    Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)

  sale    CtmSale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product CtmProduct @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}


model CtmOrder {
  id               String   @id @default(cuid())
  orderNo          String   @unique
  itemsJson        String   @db.Text
  subtotal         Decimal  @db.Decimal(10, 2)
  taxAmount        Decimal  @db.Decimal(10, 2)
  shippingFee      Decimal  @db.Decimal(10, 2)
  totalAmount      Decimal  @db.Decimal(10, 2)
  recipientName    String
  recipientPhone   String
  recipientAddress String   @db.Text
  slipUrl          String?
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())

  @@index([status])
}


model CtmCustomer {
  id           String   @id @default(cuid())
  customerCode String?  @unique
  name         String
  phone       String?
  email       String?
  address     String?  @db.Text
  nationality String?
  note        String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sales CtmSale[]

  @@index([phone])
}


model CtmSupplier {
  id           String   @id @default(cuid())
  supplierCode String?  @unique
  name         String
  company   String?
  phone     String?
  email     String?
  address   String?  @db.Text
  country   String?
  note      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model CtmTaxRecord {
  id         String   @id @default(cuid())
  period     String   @unique
  totalSales Decimal  @db.Decimal(12, 2)
  vatAmount  Decimal  @db.Decimal(10, 2)
  vatRate    Decimal  @default(0.10) @db.Decimal(5, 4)
  status     String   @default("DRAFT")
  note       String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
}


model CtmIncomeTax {
  id            String   @id @default(cuid())
  year          String
  totalRevenue  Decimal  @db.Decimal(14, 2)
  taxableIncome Decimal  @db.Decimal(14, 2)
  taxRate       Decimal  @default(0.20) @db.Decimal(5, 4)
  taxAmount     Decimal  @db.Decimal(14, 2)
  status        String   @default("DRAFT")
  note          String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([year])
  @@index([status])
}


model CtmShipping {
  id               String    @id @default(cuid())
  invoiceNo        String
  saleId           String?
  type             String    @default("DELIVERY")
  recipientName    String?
  recipientPhone   String?
  recipientAddress String?   @db.Text
  trackingNo       String?
  carrier          String?
  status           String    @default("PENDING")
  note             String?   @db.Text
  shippedAt        DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([invoiceNo])
  @@index([status])
  @@index([type])
}


model CtmDailyExpense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  category    String
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  paymentType String   @default("CASH")
  note        String?  @db.Text
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
}


model CtmWage {
  id            String   @id @default(cuid())
  period        String
  employeeName  String
  baseSalary    Decimal  @db.Decimal(10, 2)
  overtimeHours Decimal  @default(0) @db.Decimal(6, 2)
  overtimePay   Decimal  @default(0) @db.Decimal(10, 2)
  bonus         Decimal  @default(0) @db.Decimal(10, 2)
  totalPay      Decimal  @db.Decimal(10, 2)
  note          String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([period])
  @@index([employeeName])
}


model CtmAnnouncement {
  id        String   @id @default(cuid())
  lang      String   @unique
  text      String   @db.Text
  updatedAt DateTime @updatedAt
}


model CtmPartnerShare {
  id               String   @id @default(cuid())
  period           String
  partnerName      String
  sharePercent     Decimal  @db.Decimal(5, 2)
  netProfit        Decimal  @db.Decimal(14, 2)
  shareAmount      Decimal  @db.Decimal(14, 2)
  deductionAmount  Decimal  @default(0) @db.Decimal(14, 2)
  deductionNote    String?  @db.Text
  note             String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([period])
}
